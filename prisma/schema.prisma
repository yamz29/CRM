// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cliente {
  id          Int      @id @default(autoincrement())
  nombre      String
  rnc         String?  @unique // RNC (empresas) o cédula (personas)
  telefono    String?
  whatsapp    String?
  correo      String?
  direccion   String?
  tipoCliente String   @default("Particular")
  fuente      String   @default("Directo")
  notas       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  proyectos      Proyecto[]
  presupuestos   Presupuesto[]
  tareas         Tarea[]
  registrosHoras RegistroHoras[]
  oportunidades  Oportunidad[]
  facturas       Factura[]
}

model Proyecto {
  id                  Int       @id @default(autoincrement())
  nombre              String
  clienteId           Int
  tipoProyecto        String    @default("Remodelación")
  ubicacion           String?
  fechaInicio         DateTime?
  fechaEstimada       DateTime?
  estado              String    @default("Prospecto")
  descripcion         String?
  responsable         String?
  presupuestoEstimado Float?
  presupuestoBaseId   Int?      // ID del presupuesto usado como snapshot base
  avanceFisico        Int       @default(0)  // % de avance físico 0-100
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  cliente         Cliente              @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  presupuestos    Presupuesto[]
  tareas          Tarea[]
  modulosMelamina ModuloMelaminaV2[]
  gastos          GastoProyecto[]
  capitulos       ProyectoCapitulo[]
  partidas        ProyectoPartida[]
  registrosHoras  RegistroHoras[]
  oportunidades   Oportunidad[]
  cronogramas     Cronograma[]
  bitacora        BitacoraEntrada[]
  ordenesProduccion OrdenProduccion[]
  facturas          Factura[]
  adicionales       AdicionalProyecto[]
  punchlist         PunchItem[]
  ordenesCompra     OrdenCompra[]
  evmSnapshots      EVMSnapshot[]

  @@index([estado])
  @@index([clienteId, estado])
}

// ── ADICIONALES (CHANGE ORDERS) ──────────────────────────────────────────
// Modificaciones del alcance de un proyecto: trabajos extra, cambios de
// material, ampliaciones que el cliente solicita después del presupuesto
// original. El monto aprobado se suma al presupuesto vigente para
// recalcular margen y rentabilidad real del proyecto.

model AdicionalProyecto {
  id              Int       @id @default(autoincrement())
  proyectoId      Int
  numero          String?   // ej: AD-001 (opcional, para referencia del cliente)
  titulo          String
  descripcion     String?
  monto           Float     @default(0)
  estado          String    @default("propuesto") // propuesto | aprobado | rechazado | facturado
  fechaPropuesta  DateTime  @default(now())
  fechaAprobacion DateTime?
  aprobadoPor     String?   // nombre del cliente o representante que aprueba
  motivoRechazo   String?
  archivoUrl      String?   // PDF/imagen firmada por el cliente
  notas           String?
  createdById     Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  proyecto Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@index([proyectoId])
  @@index([estado])
  @@map("adicional_proyecto")
}

// ── GASTOS DEL PROYECTO ───────────────────────────────────────────────

model GastoProyecto {
  id               Int      @id @default(autoincrement())
  proyectoId       Int?     // nullable: gasto puede existir sin proyecto
  destinoTipo      String   @default("proyecto")  // proyecto|oficina|taller|general|sin_asignar
  fecha            DateTime
  tipoGasto        String   @default("Gasto menor")
  referencia       String?
  descripcion      String
  suplidor         String?
  categoria        String?
  subcategoria     String?
  monto            Float    @default(0)
  moneda           String   @default("RD$")
  metodoPago       String   @default("Efectivo")
  cuentaOrigen     String?
  observaciones    String?
  estado           String   @default("Registrado")
  archivoUrl       String?
  partidaId        Int?
  createdBy        Int?
  // Inventario
  recursoId        Int?
  cantidadRecurso  Float?
  movimientoStock  String?  // 'entrada' | 'salida' | null
  facturaId        Int?     @unique  // vínculo con factura de contabilidad
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  proyecto  Proyecto?        @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
  partida   ProyectoPartida? @relation(fields: [partidaId], references: [id], onDelete: SetNull)
  recurso   Recurso?         @relation(fields: [recursoId], references: [id], onDelete: SetNull)
  factura   Factura?         @relation(fields: [facturaId], references: [id], onDelete: SetNull)

  @@index([proyectoId])
  @@index([proyectoId, estado])
  @@index([fecha])
}

// ── ESTRUCTURA PRESUPUESTARIA DEL PROYECTO (snapshot) ─────────────────

model ProyectoCapitulo {
  id         Int      @id @default(autoincrement())
  proyectoId Int
  nombre     String
  orden      Int      @default(0)
  createdAt  DateTime @default(now())

  proyecto Proyecto          @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  partidas ProyectoPartida[]

  @@map("proyecto_capitulos")
}

model ProyectoPartida {
  id                    Int      @id @default(autoincrement())
  proyectoId            Int
  capituloId            Int?
  capituloNombre        String?  // desnormalizado para snapshot
  presupuestoOrigenId   Int?     // referencia al presupuesto origen
  codigo                String?
  descripcion           String
  unidad                String   @default("gl")
  cantidad              Float    @default(1)
  precioUnitario        Float    @default(0)
  subtotalPresupuestado Float    @default(0)
  orden                 Int      @default(0)
  observaciones         String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  proyecto Proyecto          @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  capitulo ProyectoCapitulo? @relation(fields: [capituloId], references: [id], onDelete: SetNull)
  gastos   GastoProyecto[]

  @@map("proyecto_partidas")
}

model Presupuesto {
  id             Int      @id @default(autoincrement())
  numero         String   @unique
  proyectoId     Int?
  clienteId      Int
  oportunidadId  Int?
  estado         String   @default("Borrador")
  subtotal       Float    @default(0)
  descuentoTipo  String   @default("ninguno")    // ninguno | porcentaje | fijo
  descuentoValor Float    @default(0)
  itbisActivo    Boolean  @default(false)
  itbisPorcentaje Float   @default(18)           // 18% normal o 1.8% norma 07-07
  total          Float    @default(0)
  notas          String?
  resumenIA           String?   // resumen generado por IA (markdown)
  resumenIAGeneradoAt DateTime? // cuándo se generó el último resumen
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  proyecto        Proyecto?          @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
  cliente         Cliente            @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  oportunidad     Oportunidad?       @relation(fields: [oportunidadId], references: [id], onDelete: SetNull)
  partidas        Partida[]
  modulosMelamina ModuloMelamina[]
  capitulos       CapituloPresupuesto[]
  titulos         PresupuestoTitulo[]
  indirectos      PresupuestoIndirectoLinea[]
  cronogramas     Cronograma[]

  @@index([estado])
  @@index([clienteId])
  @@index([oportunidadId])
}

// ── PRESUPUESTOS V2: Capítulos y Partidas ────────────────────────────

model PresupuestoTitulo {
  id            Int      @id @default(autoincrement())
  presupuestoId Int
  nombre        String
  orden         Int      @default(0)
  observaciones String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  presupuesto Presupuesto           @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)
  capitulos   CapituloPresupuesto[]

  @@map("presupuesto_titulos")
}

model PresupuestoIndirectoLinea {
  id            Int      @id @default(autoincrement())
  presupuestoId Int
  nombre        String
  porcentaje    Float    @default(0)
  orden         Int      @default(0)
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  presupuesto Presupuesto @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)

  @@map("presupuesto_indirecto_lineas")
}

model CapituloPresupuesto {
  id            Int      @id @default(autoincrement())
  presupuestoId Int
  tituloId      Int?
  codigo        String?
  nombre        String
  orden         Int      @default(0)
  createdAt     DateTime @default(now())

  presupuesto Presupuesto           @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)
  titulo      PresupuestoTitulo?    @relation(fields: [tituloId], references: [id], onDelete: SetNull)
  partidas    PartidaPresupuesto[]
}

model PartidaPresupuesto {
  id             Int      @id @default(autoincrement())
  capituloId     Int
  codigo         String?
  descripcion    String
  unidad         String   @default("gl")
  cantidad       Float    @default(1)
  precioUnitario Float    @default(0)
  subtotal       Float    @default(0)
  observaciones  String?
  orden          Int      @default(0)
  esNota         Boolean  @default(false)  // si true: solo descripción, no suma al total
  createdAt      DateTime @default(now())

  capitulo CapituloPresupuesto @relation(fields: [capituloId], references: [id], onDelete: Cascade)
  analisis AnalisisPartida?
}

model AnalisisPartida {
  id             Int      @id @default(autoincrement())
  partidaId      Int      @unique
  // Totales calculados (para consultas rápidas)
  materiales     Float    @default(0)
  manoObra       Float    @default(0)
  equipos        Float    @default(0)
  subcontratos   Float    @default(0)
  transporte     Float    @default(0)
  desperdicio    Float    @default(0)
  indirectos     Float    @default(0)
  utilidad       Float    @default(0)
  costoDirecto   Float    @default(0)
  costoTotal     Float    @default(0)
  precioSugerido Float    @default(0)
  margen         Float    @default(0)
  rendimiento    Float?   // unidades por día (ej: 20 m²/día) — para calcular duración en cronograma
  // Detalle de líneas por categoría (JSON)
  detalleJson    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  partida PartidaPresupuesto @relation(fields: [partidaId], references: [id], onDelete: Cascade)
}

// ── MATERIALES MELAMINA ───────────────────────────────────────────────

model MaterialMelamina {
  id            Int      @id @default(autoincrement())
  tipo          String   // 'tablero' | 'canto' | 'herraje'
  nombre        String
  codigo        String?
  marca         String?
  proveedor     String?
  precio        Float    @default(0)
  moneda        String   @default("DOP")
  unidad        String   @default("ud")
  anchoMm       Float?   // tablero: 2440, canto: 22
  largoMm       Float?   // tablero: 1830
  espesorMm     Float?   // tablero: 18, canto: 0.4
  activo        Boolean  @default(true)
  observaciones String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  materialesModulo MaterialModuloMelamina[]
  modulosTablero   ModuloMelaminaV2[]       @relation("ModuloTableroMaterial")
  materialesOrden  MaterialOrdenProduccion[]

  @@map("material_melamina")
}

model MaterialModuloMelamina {
  id            Int      @id @default(autoincrement())
  moduloId      Int
  materialId    Int
  tipo          String   @default("herraje") // 'canto' | 'herraje'
  unidad        String   @default("ud")
  cantidad      Float    @default(1)
  costoSnapshot Float    @default(0)
  subtotal      Float    @default(0)
  observaciones String?
  orden         Int      @default(0)
  createdAt     DateTime @default(now())

  modulo   ModuloMelaminaV2 @relation(fields: [moduloId], references: [id], onDelete: Cascade)
  material MaterialMelamina @relation(fields: [materialId], references: [id])

  @@map("material_modulo_melamina")
}

// ── MÓDULOS MELAMINA V2 ───────────────────────────────────────────────

model ModuloMelaminaV2 {
  id                 Int      @id @default(autoincrement())
  proyectoId         Int?
  presupuestoId      Int?
  codigo             String?
  tipoModulo         String   @default("Base con puertas")
  nombre             String
  ancho              Float    @default(0)
  alto               Float    @default(0)
  profundidad        Float    @default(0)
  cantidadPuertas    Int      @default(0)
  cantidadCajones    Int      @default(0)
  material           String   @default("Melamina Egger 18mm")
  colorAcabado       String?
  herrajes           String?
  cantidad           Int      @default(1)
  costoMateriales    Float    @default(0)
  costoManoObra      Float    @default(0)
  costoInstalacion   Float    @default(0)
  precioVenta        Float    @default(0)
  estadoProduccion   String   @default("Diseño")
  observaciones      String?
  recursoTableroId   Int?
  anchoPlanchaCm     Float    @default(2440)
  largoPlanchaCm     Float    @default(1830)
  materialTableroId  Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  proyecto          Proyecto?                @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
  materialTablero   MaterialMelamina?        @relation("ModuloTableroMaterial", fields: [materialTableroId], references: [id])
  piezas            PiezaModulo[]
  recursosModulo    RecursoModulo[]
  materialesModulo  MaterialModuloMelamina[]
  kitchenPlacements KitchenModulePlacement[]
}

model PiezaModulo {
  id               Int      @id @default(autoincrement())
  moduloId         Int
  etiqueta         String   @default("Otro")
  nombre           String
  tipoPieza        String   @default("otro")
  largo            Float    @default(0)
  ancho            Float    @default(0)
  cantidad         Int      @default(1)
  espesor          Float    @default(18)
  material         String?
  tapacanto        String   @default("[]")
  llevaMecanizado  Boolean  @default(false)
  tipoMecanizado   String?  // bisagras, ranuras, minifix, otro (comma-separated)
  observaciones    String?
  orden            Int      @default(0)
  createdAt        DateTime @default(now())

  modulo ModuloMelaminaV2 @relation(fields: [moduloId], references: [id], onDelete: Cascade)

  @@map("piezas_modulo")
}

model RecursoModulo {
  id            Int      @id @default(autoincrement())
  moduloId      Int
  recursoId     Int?
  descripcion   String?
  unidad        String   @default("und")
  cantidad      Float    @default(1)
  costoSnapshot Float    @default(0)
  subtotal      Float    @default(0)
  observaciones String?
  orden         Int      @default(0)
  createdAt     DateTime @default(now())

  modulo  ModuloMelaminaV2 @relation(fields: [moduloId], references: [id], onDelete: Cascade)
  recurso Recurso?         @relation(fields: [recursoId], references: [id])

  @@map("recursos_modulo")
}

// ── TAREAS ────────────────────────────────────────────────────────────

model Tarea {
  id              Int       @id @default(autoincrement())
  titulo          String
  descripcion     String?
  clienteId       Int?
  proyectoId      Int?
  oportunidadId   Int?
  asignadoId      Int?
  fechaLimite     DateTime?
  prioridad       String    @default("Media")
  estado          String    @default("Pendiente")
  avance          Int       @default(0)
  responsable     String?
  etapaPipeline   String?   // etapa de la oportunidad que originó esta tarea
  archivada       Boolean   @default(false)
  fechaArchivada  DateTime?
  fechaCompletada DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  cliente     Cliente?      @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  proyecto    Proyecto?     @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
  oportunidad Oportunidad?  @relation(fields: [oportunidadId], references: [id], onDelete: SetNull)
  asignado    Usuario?      @relation(fields: [asignadoId], references: [id], onDelete: SetNull)

  @@index([oportunidadId])
}

// ── LEGACY (se mantienen para compatibilidad) ─────────────────────────

model Partida {
  id             Int      @id @default(autoincrement())
  presupuestoId  Int
  descripcion    String
  unidad         String   @default("m2")
  cantidad       Float    @default(1)
  precioUnitario Float    @default(0)
  subtotal       Float    @default(0)
  orden          Int      @default(0)
  createdAt      DateTime @default(now())

  presupuesto Presupuesto @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)
}

model ModuloMelamina {
  id             Int      @id @default(autoincrement())
  presupuestoId  Int
  tipoModulo     String   @default("Base")
  descripcion    String
  ancho          Float    @default(0)
  alto           Float    @default(0)
  profundidad    Float    @default(0)
  material       String   @default("Melamina 18mm")
  costoMaterial  Float    @default(0)
  costoManoObra  Float    @default(0)
  subtotal       Float    @default(0)
  cantidad       Int      @default(1)
  orden          Int      @default(0)
  createdAt      DateTime @default(now())

  presupuesto Presupuesto @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)
}

// ── CATÁLOGO DE RECURSOS ──────────────────────────────────────────────

model Recurso {
  id             Int      @id @default(autoincrement())
  codigo         String?
  nombre         String
  tipo           String   @default("materiales") // materiales | manoObra | equipos | herramientas | subcontratos | transportes | herrajes | consumibles
  categoria      String?
  subcategoria   String?
  unidad         String   @default("gl")
  costoUnitario  Float    @default(0)
  proveedor      String?
  marca          String?
  activo         Boolean  @default(true)
  observaciones  String?
  // Inventario
  controlarStock Boolean  @default(false)
  stock          Float    @default(0)
  stockMinimo    Float    @default(0)
  ultimoCosto    Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  apuRecursos      ApuRecurso[]
  gastos           GastoProyecto[]
  recursosModulo   RecursoModulo[]
  historialPrecios RecursoPriceHistory[]
}

// ── HISTÓRICO DE PRECIOS DE RECURSOS ──────────────────────────────────

model RecursoPriceHistory {
  id                Int      @id @default(autoincrement())
  recursoId         Int
  codigoSnapshot    String?
  nombreSnapshot    String
  precioAnterior    Float
  precioNuevo       Float
  moneda            String   @default("DOP")
  unidadSnapshot    String
  origenCambio      String   @default("manual") // manual | importacion
  loteImportacionId Int?
  observacion       String?
  createdAt         DateTime @default(now())

  recurso           Recurso             @relation(fields: [recursoId], references: [id], onDelete: Cascade)
  loteImportacion   RecursoImportBatch? @relation(fields: [loteImportacionId], references: [id])

  @@map("recurso_price_history")
}

// ── LOTES DE IMPORTACIÓN DE RECURSOS ──────────────────────────────────

model RecursoImportBatch {
  id                Int      @id @default(autoincrement())
  nombreArchivo     String
  totalFilas        Int      @default(0)
  filasCreadas      Int      @default(0)
  filasActualizadas Int      @default(0)
  filasConError     Int      @default(0)
  preciosCambiados  Int      @default(0)
  observaciones     String?
  createdAt         DateTime @default(now())

  historialPrecios  RecursoPriceHistory[]

  @@map("recurso_import_batches")
}

// ── CATÁLOGO DE APUs ──────────────────────────────────────────────────

model ApuCatalogo {
  id            Int      @id @default(autoincrement())
  codigo        String?
  nombre        String
  descripcion   String?
  capitulo      String?
  unidad        String   @default("gl")
  indirectos    Float    @default(10)
  utilidad      Float    @default(20)
  desperdicio   Float    @default(5)
  rendimiento   Float?   // unidades por día — para calcular duración en cronograma
  volumenAnalisis Float? // volumen de análisis — el precio de venta se divide entre este valor (null/0 = 1)
  costoDirecto  Float    @default(0)
  costoTotal    Float    @default(0)
  precioVenta   Float    @default(0)
  activo        Boolean  @default(true)
  observaciones String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  recursos      ApuRecurso[] @relation("ApuComposicion")
  comoHijo      ApuRecurso[] @relation("ApuHijo")
}

// ── COMPOSICIÓN APU ← RECURSOS / SUB-APUs ────────────────────────────

model ApuRecurso {
  id               Int      @id @default(autoincrement())
  apuId            Int
  tipoComponente   String   @default("recurso")  // 'recurso' | 'apu' | 'libre'
  recursoId        Int?     // null si es línea libre o APU hijo
  apuHijoId        Int?     // referencia al APU hijo cuando tipoComponente = 'apu'
  nombreSnapshot   String?  // snapshot de nombre del APU hijo
  unidadSnapshot   String?  // snapshot de unidad del APU hijo
  descripcionLibre String?  // texto libre cuando no hay recurso del catálogo
  unidadLibre      String?  // unidad para línea libre
  tipoLinea        String?  // sección: materiales|manoObra|equipos|etc
  cantidad         Float    @default(1)
  costoSnapshot    Float    @default(0)
  subtotal         Float    @default(0)
  orden            Int      @default(0)
  observaciones    String?
  createdAt        DateTime @default(now())

  apu     ApuCatalogo  @relation("ApuComposicion", fields: [apuId], references: [id], onDelete: Cascade)
  recurso Recurso?     @relation(fields: [recursoId], references: [id])
  apuHijo ApuCatalogo? @relation("ApuHijo", fields: [apuHijoId], references: [id])
}

// ── CONFIGURACIÓN ─────────────────────────────────────────────────────

model Empresa {
  id        Int      @id @default(autoincrement())
  nombre    String   @default("Mi Empresa")
  rut       String?
  direccion String?
  telefono  String?
  correo    String?
  sitioWeb  String?
  logoUrl   String?
  slogan    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vendedor {
  id        Int      @id @default(autoincrement())
  nombre    String
  telefono  String?
  correo    String?
  cargo     String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Categoria {
  id          Int      @id @default(autoincrement())
  nombre      String
  tipo        String   @default("Proyecto")
  color       String   @default("#3b82f6")
  descripcion String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nombre    String
  correo    String   @unique
  password  String?
  rol       String   @default("Admin")
  activo    Boolean  @default(true)
  costoHora Float    @default(0)  // costo por hora para calcular mano de obra interna
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tareas         Tarea[]
  registrosHoras RegistroHoras[]
  permisos       PermisoUsuario[]
  bitacora       BitacoraEntrada[]
  asignacionesProduccion AsignacionProduccion[]
}

model PermisoUsuario {
  id        Int    @id @default(autoincrement())
  usuarioId Int
  modulo    String // dashboard|clientes|oportunidades|presupuestos|proyectos|cronogramas|gastos|contabilidad|proveedores|compras|recursos|apus|tareas|horas|melamina|cocinas|produccion|configuracion
  nivel     String @default("editar") // ninguno | ver | editar | admin

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, modulo])
  @@index([usuarioId])
  @@map("permiso_usuario")
}

model Configuracion {
  id    Int    @id @default(autoincrement())
  clave String @unique
  valor String
}

// ── UNIDADES GLOBALES ──────────────────────────────────────────────────

// ── REGISTRO DE HORAS DEL EQUIPO ─────────────────────────────────────

model RegistroHoras {
  id            Int      @id @default(autoincrement())
  usuarioId     Int?
  proyectoId    Int?
  clienteId     Int?
  fecha         DateTime
  horas         Float    @default(1)
  tipoActividad String   // 'Proyecto' | 'Prospección' | 'Levantamiento' | 'Cotización' | 'Limpieza' | 'Organización' | 'Transporte' | 'Reunión' | 'Taller'
  nota          String?
  horaInicio    Float?   // 8.0 = 8am, 14.5 = 2:30pm; null = sin horario específico
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  usuario  Usuario?  @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  proyecto Proyecto? @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
  cliente  Cliente?  @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  @@index([usuarioId])
  @@index([proyectoId])
  @@index([fecha])
  @@map("registro_horas")
}

model UnidadGlobal {
  id          Int      @id @default(autoincrement())
  codigo      String   @unique // ej: m2, ml, kg
  nombre      String           // ej: Metro cuadrado
  simbolo     String?          // ej: m²
  tipo        String   @default("otro") // longitud | area | volumen | unidad | tiempo | peso | otro
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── CONFIGURADOR DE COCINAS ───────────────────────────────────────────────────

model KitchenProject {
  id         Int      @id @default(autoincrement())
  nombre     String
  layoutType String   @default("lineal") // lineal | L | U
  alturaMm   Float    @default(2400)
  profBase   Float    @default(580)   // depth of base cabinets mm
  profAlto   Float    @default(350)   // depth of wall cabinets mm
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  paredes    KitchenWall[]
  placements KitchenModulePlacement[]

  @@map("kitchen_project")
}

model KitchenWall {
  id               Int    @id @default(autoincrement())
  kitchenProjectId Int
  nombre           String // A, B, C
  longitud         Float  // mm
  orden            Int    @default(0)
  x                Float  @default(0)   // origin x mm (top-left of wall start)
  y                Float  @default(0)   // origin y mm
  angulo           Float  @default(0)   // 0=right, 90=down, 180=left, 270=up

  proyecto   KitchenProject         @relation(fields: [kitchenProjectId], references: [id], onDelete: Cascade)
  placements KitchenModulePlacement[]

  @@map("kitchen_wall")
}

model KitchenModulePlacement {
  id                Int    @id @default(autoincrement())
  kitchenProjectId  Int
  wallId            Int?   // null = isla/peninsular (free placement)
  moduloId          Int
  posicion          Float  @default(0)    // mm from start of wall (wall-based)
  nivel             String @default("base") // base | alto | torre | isla
  alturaDesdeSupelo Float  @default(1400) // mm from floor (relevant for nivel=alto)
  posX              Float  @default(0)   // absolute mm X in plan (for islands)
  posY              Float  @default(0)   // absolute mm Y in plan (for islands)

  proyecto KitchenProject   @relation(fields: [kitchenProjectId], references: [id], onDelete: Cascade)
  wall     KitchenWall?     @relation(fields: [wallId], references: [id], onDelete: Cascade)
  modulo   ModuloMelaminaV2 @relation(fields: [moduloId], references: [id], onDelete: Cascade)

  @@map("kitchen_module_placement")
}

// ── PIPELINE DE VENTAS ────────────────────────────────────────────────

model Oportunidad {
  id             Int       @id @default(autoincrement())
  clienteId      Int
  nombre         String
  etapa          String    @default("Lead")
  // etapas: Lead | Levantamiento | Cotización | Negociación | Ganado | Perdido
  valor          Float?
  moneda         String    @default("DOP")
  probabilidad   Int?      // 0-100
  fechaCierreEst DateTime?
  responsable    String?
  motivoPerdida  String?
  notas          String?
  proyectoId     Int?
  archivada      Boolean   @default(false)
  fechaArchivada DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  cliente      Cliente       @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  proyecto     Proyecto?     @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
  actividades  ActividadCRM[]
  presupuestos Presupuesto[]
  tareas       Tarea[]

  @@index([etapa])
  @@index([clienteId, etapa])
  @@index([responsable])
}

model ActividadCRM {
  id            Int         @id @default(autoincrement())
  oportunidadId Int
  tipo          String      // Llamada | WhatsApp | Reunión | Visita | Correo | Nota
  descripcion   String
  fecha         DateTime    @default(now())
  createdAt     DateTime    @default(now())

  oportunidad Oportunidad @relation(fields: [oportunidadId], references: [id], onDelete: Cascade)

  @@map("actividad_crm")
}

model PlantillaTareaEtapa {
  id          Int     @id @default(autoincrement())
  etapa       String  // Lead | Levantamiento | Cotización | Negociación
  titulo      String
  descripcion String?
  prioridad   String  @default("Media")
  diasLimite  Int?    // días desde que entra a la etapa para calcular fechaLimite
  orden       Int     @default(0)
  activa      Boolean @default(true)

  @@index([etapa])
  @@map("plantilla_tarea_etapa")
}

// ── CRONOGRAMA DE OBRA ────────────────────────────────────────────────

model Cronograma {
  id               Int       @id @default(autoincrement())
  nombre           String
  proyectoId       Int?
  presupuestoId    Int?
  fechaInicio      DateTime
  fechaFinEstimado DateTime?
  estado           String    @default("Planificado")
  // Planificado | En Ejecución | Terminado | Pausado
  version          Int       @default(1)
  notas            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  proyecto     Proyecto?             @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
  presupuesto  Presupuesto?          @relation(fields: [presupuestoId], references: [id], onDelete: SetNull)
  actividades  ActividadCronograma[]

  @@index([proyectoId])
  @@index([estado])
  @@map("cronograma")
}

model ActividadCronograma {
  id              Int      @id @default(autoincrement())
  cronogramaId    Int
  partidaId       Int?     // referencia a PartidaPresupuesto (opcional)
  capituloNombre  String?  // nombre del capítulo para agrupar en Gantt
  nombre          String
  descripcion     String?
  duracion        Int      @default(1)    // días calendario
  fechaInicio     DateTime
  fechaFin        DateTime
  pctAvance       Float    @default(0)   // 0-100
  estado          String   @default("Pendiente")
  // Pendiente | En Ejecución | Completado | Atrasado
  tipo            String   @default("tarea") // tarea | hito
  wbs             String?  // código WBS ej: 1.1, 1.2.3
  dependenciaId   Int?
  tipoDependencia String   @default("FS") // FS=Fin-Inicio | SS=Inicio-Inicio
  cuadrilla       String?  // nombre de la cuadrilla asignada
  orden           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cronograma  Cronograma            @relation(fields: [cronogramaId], references: [id], onDelete: Cascade)
  dependencia ActividadCronograma?  @relation("Dependencia", fields: [dependenciaId], references: [id], onDelete: SetNull)
  dependientes ActividadCronograma[] @relation("Dependencia")
  avances     AvanceCronograma[]

  @@index([cronogramaId])
  @@index([dependenciaId])
  @@map("actividad_cronograma")
}

model AvanceCronograma {
  id          Int      @id @default(autoincrement())
  actividadId Int
  fecha       DateTime @default(now())
  pctAvance   Float
  comentario  String?
  usuarioId   Int?
  createdAt   DateTime @default(now())

  actividad ActividadCronograma @relation(fields: [actividadId], references: [id], onDelete: Cascade)

  @@index([actividadId])
  @@map("avance_cronograma")
}

// ── BITÁCORA DE OBRA ──────────────────────────────────────────────────

model BitacoraEntrada {
  id             Int      @id @default(autoincrement())
  proyectoId     Int
  usuarioId      Int?
  fecha          DateTime
  tipo           String   @default("Avance")  // Avance | Problema | Inspección | General
  descripcion    String
  clima          String?  // Soleado | Nublado | Lluvia | Tormenta
  personalEnObra Int?
  avancePct      Int?     // si se llena, actualiza avanceFisico del proyecto
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  proyecto Proyecto  @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  usuario  Usuario?  @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  fotos    BitacoraFoto[]

  @@index([proyectoId, fecha])
  @@map("bitacora_entradas")
}

model BitacoraFoto {
  id        Int      @id @default(autoincrement())
  entradaId Int
  url       String
  caption   String?
  createdAt DateTime @default(now())

  entrada BitacoraEntrada @relation(fields: [entradaId], references: [id], onDelete: Cascade)

  @@index([entradaId])
  @@map("bitacora_fotos")
}

// ── PRODUCCIÓN ───────────────────────────────────────────────────────

model OrdenProduccion {
  id                Int       @id @default(autoincrement())
  codigo            String    @unique
  nombre            String
  proyectoId        Int?
  clienteNombre     String?
  presupuestoOrigen Int?
  espacioOrigenId   Int?
  etapaActual       String    @default("Compra de Materiales")
  prioridad         String    @default("Media")
  estado            String    @default("Pendiente")
  fechaInicio       DateTime?
  fechaEstimada     DateTime?
  fechaCompletada   DateTime?
  notas              String?
  checklistQCProceso String?
  checklistQCFinal   String?
  notasQCProceso     String?
  notasQCFinal       String?
  etapasLog          String?    // JSON: [{etapa, inicio, fin}]
  progresoPiezas     String?    // JSON: {piezaId: {canteado, mecanizado}}
  creadoPorId        Int?
  empresaId         Int       @default(1)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  proyecto     Proyecto?                @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
  items        ItemProduccion[]
  materiales   MaterialOrdenProduccion[]
  asignaciones AsignacionProduccion[]

  @@index([estado])
  @@index([etapaActual])
  @@index([empresaId])
  @@map("orden_produccion")
}

model ItemProduccion {
  id                 Int       @id @default(autoincrement())
  ordenId            Int
  moduloId           Int?
  nombreModulo       String
  tipoModulo         String?
  dimensiones        String?
  cantidad           Int       @default(1)
  observaciones      String?
  completado         Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  orden        OrdenProduccion        @relation(fields: [ordenId], references: [id], onDelete: Cascade)
  asignaciones AsignacionProduccion[]

  @@index([ordenId])
  @@map("item_produccion")
}

model AsignacionProduccion {
  id        Int      @id @default(autoincrement())
  itemId    Int?
  ordenId   Int?
  usuarioId Int
  etapa     String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())

  item    ItemProduccion?  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  orden   OrdenProduccion? @relation(fields: [ordenId], references: [id], onDelete: Cascade)
  usuario Usuario          @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([ordenId])
  @@index([usuarioId])
  @@map("asignacion_produccion")
}

model MaterialOrdenProduccion {
  id                Int      @id @default(autoincrement())
  ordenId           Int
  materialId        Int?
  nombre            String
  tipo              String?
  unidad            String   @default("ud")
  cantidadRequerida Float    @default(0)
  cantidadComprada  Float    @default(0)
  cantidadRecibida  Float    @default(0)
  costoUnitario     Float    @default(0)
  costoTotal        Float    @default(0)
  proveedor         String?
  estado            String   @default("Pendiente")
  notas             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  orden    OrdenProduccion   @relation(fields: [ordenId], references: [id], onDelete: Cascade)
  material MaterialMelamina? @relation(fields: [materialId], references: [id], onDelete: SetNull)

  @@index([ordenId])
  @@map("material_orden_produccion")
}

// ── CONTABILIDAD ─────────────────────────────────────────────────────────

model CuentaBancaria {
  id            Int      @id @default(autoincrement())
  nombre        String                             // ej: "Cuenta Principal BHD"
  banco         String                             // ej: "Banco BHD"
  numeroCuenta  String?                            // parcial o enmascarado
  tipoCuenta    String   @default("corriente")     // corriente | ahorro
  moneda        String   @default("RD$")
  saldoInicial  Float    @default(0)
  activa        Boolean  @default(true)
  creadoEn      DateTime @default(now())

  movimientos MovimientoBancario[]
  pagos       PagoFactura[]

  @@map("cuenta_bancaria")
}

// ── PROVEEDORES ──────────────────────────────────────────────────────
// Catálogo normalizado de proveedores / suplidores.
// Las facturas de egreso pueden enlazarse opcionalmente a un proveedor.

model Proveedor {
  id               Int       @id @default(autoincrement())
  nombre           String
  rnc              String?   @unique // RNC (empresas) o cédula (personas)
  telefono         String?
  contacto         String?   // nombre del contacto principal
  correo           String?
  direccion        String?
  condicionesPago  String?   // ej: "30 días", "contado"
  notas            String?
  activo           Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  facturas         Factura[]
  ordenesCompra    OrdenCompra[]

  @@map("proveedor")
}

model Factura {
  id               Int       @id @default(autoincrement())
  numero           String                            // número de factura
  ncf              String?                            // NCF / e-CF (comprobante fiscal)
  tipo             String                             // ingreso | egreso
  fecha            DateTime
  fechaVencimiento DateTime?

  // Egreso → proveedor (catálogo normalizado + texto legacy)
  proveedorId      Int?
  proveedorRef     Proveedor? @relation(fields: [proveedorId], references: [id], onDelete: SetNull)
  proveedor        String?                            // nombre denormalizado / legacy
  rncProveedor     String?                            // RNC del proveedor
  // Ingreso → cliente existente
  clienteId        Int?
  cliente          Cliente?  @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  // Destino del gasto
  destinoTipo      String    @default("general")      // proyecto | oficina | taller | general
  proyectoId       Int?
  proyecto         Proyecto? @relation(fields: [proyectoId], references: [id], onDelete: SetNull)

  descripcion      String?
  subtotal         Float     @default(0)
  impuesto         Float     @default(0)              // ITBIS
  total            Float     @default(0)
  montoPagado      Float     @default(0)              // sum of pagos

  estado           String    @default("pendiente")    // pendiente | parcial | pagada | anulada
  archivoUrl       String?                            // foto o scan (local)
  driveUrl         String?                            // Google Drive link
  observaciones    String?

  creadoEn         DateTime  @default(now())
  actualizadoEn    DateTime  @updatedAt

  pagos            PagoFactura[]
  movimientos      MovimientoBancario[]
  gasto            GastoProyecto?

  @@index([tipo])
  @@index([estado])
  @@index([clienteId])
  @@index([proveedorId])
  @@index([proyectoId])
  @@index([fecha])
  @@map("factura")
}

model PagoFactura {
  id               Int       @id @default(autoincrement())
  facturaId        Int
  factura          Factura   @relation(fields: [facturaId], references: [id], onDelete: Cascade)

  fecha            DateTime
  monto            Float
  metodoPago       String    @default("Transferencia") // Efectivo | Transferencia | Cheque | Tarjeta
  referencia       String?                              // nro. cheque, ref transferencia

  cuentaBancariaId Int?
  cuentaBancaria   CuentaBancaria? @relation(fields: [cuentaBancariaId], references: [id], onDelete: SetNull)

  observaciones    String?
  creadoEn         DateTime  @default(now())

  @@index([facturaId])
  @@index([cuentaBancariaId])
  @@map("pago_factura")
}

model MovimientoBancario {
  id               Int       @id @default(autoincrement())
  cuentaBancariaId Int
  cuentaBancaria   CuentaBancaria @relation(fields: [cuentaBancariaId], references: [id], onDelete: Cascade)

  fecha            DateTime
  tipo             String                              // debito | credito
  monto            Float
  descripcion      String
  referencia       String?

  conciliado       Boolean   @default(false)
  facturaId        Int?
  factura          Factura?  @relation(fields: [facturaId], references: [id], onDelete: SetNull)

  creadoEn         DateTime  @default(now())

  @@index([cuentaBancariaId])
  @@index([conciliado])
  @@map("movimiento_bancario")
}

// ── ÓRDENES DE COMPRA ────────────────────────────────────────────────
// Documento formal de solicitud de materiales a un proveedor.
// Estados: borrador → enviada → recibida_parcial → recibida → facturada → cancelada

model OrdenCompra {
  id              Int       @id @default(autoincrement())
  numero          String    @unique           // OC-2026-0001
  proveedorId     Int?
  proyectoId      Int?
  estado          String    @default("borrador") // borrador|enviada|recibida_parcial|recibida|facturada|cancelada
  fechaEmision    DateTime  @default(now())
  fechaEntrega    DateTime?                   // fecha estimada de entrega
  fechaRecepcion  DateTime?                   // fecha real de recepción
  condicionesPago String?                     // ej: "30 días", "contado"
  moneda          String    @default("RD$")
  subtotal        Float     @default(0)
  impuesto        Float     @default(0)
  total           Float     @default(0)
  notas           String?
  creadoPorId     Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  proveedor  Proveedor?      @relation(fields: [proveedorId], references: [id], onDelete: SetNull)
  proyecto   Proyecto?        @relation(fields: [proyectoId], references: [id], onDelete: SetNull)
  items      ItemOrdenCompra[]

  @@index([estado])
  @@index([proveedorId])
  @@index([proyectoId])
  @@index([fechaEmision])
  @@map("orden_compra")
}

model ItemOrdenCompra {
  id                Int      @id @default(autoincrement())
  ordenCompraId     Int
  descripcion       String
  unidad            String   @default("ud")
  cantidad          Float    @default(1)
  cantidadRecibida  Float    @default(0)
  precioUnitario    Float    @default(0)
  subtotal          Float    @default(0)
  observaciones     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  ordenCompra OrdenCompra @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)

  @@index([ordenCompraId])
  @@map("item_orden_compra")
}

// ── EVM SNAPSHOTS ────────────────────────────────────────────────────
// Earned Value Management: foto periódica del estado financiero del proyecto
// para construir curvas S (PV, EV, AC) y calcular SPI/CPI.

model EVMSnapshot {
  id              Int      @id @default(autoincrement())
  proyectoId      Int
  fecha           DateTime @default(now())
  avanceFisico    Float    @default(0)       // % avance real 0-100
  presupuestoBase Float    @default(0)       // BAC (Budget at Completion)
  valorPlanificado Float   @default(0)       // PV (Planned Value) a la fecha
  valorGanado     Float    @default(0)       // EV (Earned Value) = BAC × avance%
  costoReal       Float    @default(0)       // AC (Actual Cost) gastado a la fecha
  spi             Float?                     // Schedule Performance Index = EV/PV
  cpi             Float?                     // Cost Performance Index = EV/AC
  eac             Float?                     // Estimate at Completion = BAC/CPI
  notas           String?
  createdAt       DateTime @default(now())

  proyecto Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@index([proyectoId, fecha])
  @@map("evm_snapshot")
}

// ── PUNCHLIST (Pendientes pre-entrega) ───────────────────────────────
// Lista de detalles/defectos que deben resolverse antes de la entrega
// formal de la obra al cliente. Flujo de 5 estados.

model PunchItem {
  id              Int       @id @default(autoincrement())
  proyectoId      Int
  titulo          String
  descripcion     String?
  ubicacion       String?   // ej: "Baño principal 2do piso", "Cocina"
  categoria       String?   // ej: "Pintura", "Plomería", "Eléctrico", "Acabado"
  prioridad       String    @default("media")  // baja | media | alta | critica
  estado          String    @default("abierto") // abierto | en_progreso | resuelto | verificado | cerrado
  asignadoA       String?   // nombre del responsable de resolver
  fechaLimite     DateTime?
  fotos           String?   // JSON array de URLs ["url1","url2"]
  resolucionNotas String?   // notas de quién resolvió
  resueltoEn      DateTime?
  verificadoPor   String?   // nombre del cliente o PM que verificó
  verificadoEn    DateTime?
  createdById     Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  proyecto Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  @@index([proyectoId])
  @@index([estado])
  @@index([prioridad])
  @@map("punch_item")
}
