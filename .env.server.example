# Plantilla de variables de entorno para PM2 / producción.
#
# Copiar a /var/www/crm/.env.server en el servidor (nunca commitear).
# chmod 600 .env.server
#
# Un solo archivo para ambas apps (prod + test). ecosystem.config.js mapea
# DATABASE_URL_PROD → crm-prod y DATABASE_URL_TEST → crm-test automáticamente.

# ── Bases de datos PostgreSQL ──────────────────────────────────────
DATABASE_URL_PROD=postgresql://gonzalva_user:CONTRASEÑA@localhost:5432/gonzalva_prod
DATABASE_URL_TEST=postgresql://gonzalva_user:CONTRASEÑA@localhost:5432/gonzalva_test

# ── Autenticación ──────────────────────────────────────────────────
# OBLIGATORIO. Generar uno nuevo con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REEMPLAZAR_CON_64_CARACTERES_ALEATORIOS

# ── Google Gemini (chat IA) ────────────────────────────────────────
# Opcional. Sin esto el widget de IA no responde.
# Obtener en https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Google Drive (documentos) ──────────────────────────────────────
# Opcional. JSON de cuenta de servicio en una sola línea (escapar comillas).
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_DRIVE_FOLDER_ID=

# ── Microsoft / SharePoint ─────────────────────────────────────────
# Usadas por el cliente (NEXT_PUBLIC_*) para MSAL + Graph.
NEXT_PUBLIC_AZURE_CLIENT_ID="..."
NEXT_PUBLIC_AZURE_TENANT_ID="..."
NEXT_PUBLIC_SP_HOSTNAME="tuempresa.sharepoint.com"
NEXT_PUBLIC_SP_SITE_PATH="/sites/tusite"
NEXT_PUBLIC_SP_ROOT_FOLDER="Proyectos"

# Opcional: flujo server-side de SharePoint (si lo usas).
# AZURE_CLIENT_SECRET=
# SHAREPOINT_SITE_ID=
