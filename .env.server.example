# Plantilla de variables de entorno para PM2 / producción
#
# Copiar a uno de estos archivos en el servidor (nunca commiteadas):
#   /var/www/crm/.env.server.prod
#   /var/www/crm/.env.server.test
#
# Generar JWT_SECRET nuevo:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"

# Base de datos PostgreSQL
DATABASE_URL=postgresql://gonzalva_user:CONTRASEÑA_AQUI@localhost:5432/gonzalva_prod

# Autenticación — 64+ caracteres aleatorios
JWT_SECRET=REEMPLAZAR_CON_64_CARACTERES_ALEATORIOS

# Google Gemini (chat IA) — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Google Drive (documentos) — JSON de cuenta de servicio en una sola línea
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_DRIVE_FOLDER_ID=

# Microsoft Graph / SharePoint (opcional)
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# SHAREPOINT_SITE_ID=
