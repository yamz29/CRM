# ─────────────────────────────────────────────────────────────
# .env.example — Referencia de variables requeridas
# En el VPS los secrets reales van dentro de ecosystem.config.js
# (nunca commitear archivos .env con valores reales)
# ─────────────────────────────────────────────────────────────

# Base de datos SQLite
# Producción: file:./data/prod.db
# Test:       file:./data/test.db
DATABASE_URL="file:./data/prod.db"

# JWT — generar con: openssl rand -hex 32
JWT_SECRET="cambiar_por_un_secret_largo_y_aleatorio"

# Gemini API key — obtener en https://aistudio.google.com/apikey
# Se usa para OCR de facturas (visión IA)
GEMINI_API_KEY=""

# Google Drive — para guardar facturas escaneadas
# 1. Crear cuenta de servicio en Google Cloud Console
# 2. Descargar JSON de credenciales
# 3. Pegar el JSON completo como string en GOOGLE_SERVICE_ACCOUNT_KEY
# 4. Crear carpeta en Drive y compartirla con el email de la cuenta de servicio
# 5. Pegar el ID de la carpeta (la parte después de /folders/ en la URL)
GOOGLE_SERVICE_ACCOUNT_KEY=""
GOOGLE_DRIVE_FOLDER_ID=""

# Azure / OneDrive integration
# Registrar app en Azure AD: portal.azure.com > App registrations
# Permisos: Files.Read.All, Files.ReadWrite.All, Sites.Read.All, User.Read
NEXT_PUBLIC_AZURE_CLIENT_ID=""
NEXT_PUBLIC_AZURE_TENANT_ID=""
